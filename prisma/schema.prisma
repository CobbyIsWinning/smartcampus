generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  FACULTY
  ADMINISTRATOR
  MAINTENANCE_STAFF
  MAINTENANCE_SUPERVISOR
  EVENT_ORGANIZER
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_MAINTENANCE
  UNDER_REVIEW
  LOST
  RETIRED
  DISPOSED
}

enum AssetChangeType {
  CREATED
  LOCATION_CHANGED
  ALLOCATED
  RETURNED
  TRANSFER_REQUESTED
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  STATUS_CHANGED
  SCANNED
}

enum FacilityCategory {
  ROOM
  LAB
  HALL
  SPORTS
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum RegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
}

model User {
  id             String              @id @default(cuid())
  name           String
  email          String              @unique
  passwordHash   String
  role           Role                @default(STUDENT)
  studentId      String?
  department     String?
  phone          String?
  sessionToken   String?             @unique
  sessionExpires DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tickets         MaintenanceTicket[] @relation("TicketRequester")
  assignedTickets MaintenanceTicket[] @relation("TicketAssignee")
  notifications   Notification[]
  // Epic 2 (Facility Booking) back-reference
  bookings        Booking[]
  // Epic 3 (Asset Tracking) back-references — see asset.actions.ts.
  allocatedAssets     Asset[]        @relation("AssetAssignee")
  transferAssets      Asset[]        @relation("AssetTransferTarget")
  assetHistoryEntries AssetHistory[] @relation("AssetHistoryActor")
  // Epic 5 (Events) back-references
  organizedEvents    Event[]             @relation("EventOrganizer")
  eventRegistrations EventRegistration[] @relation("EventAttendee")
  eventFeedback      EventFeedback[]     @relation("EventFeedbackAuthor")
}

model MaintenanceTicket {
  id           String         @id @default(cuid())
  title        String
  description  String
  location     String
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  requesterId  String
  assignedToId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  requester    User           @relation("TicketRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedTo   User?          @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id                   String         @id @default(cuid())
  assetId              String         @unique
  qrToken              String         @unique
  name                 String
  category             String
  serialNumber         String         @unique
  purchaseDate         DateTime?
  cost                 Float?
  condition            String?
  status               AssetStatus    @default(AVAILABLE)
  owningDepartment     String?
  building             String?
  room                 String?
  storage              String?
  location             String?
  assignedToId         String?
  responsiblePerson    String?
  assignedDate         DateTime?
  transferToId         String?
  transferToDepartment String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  assignedTo           User?          @relation("AssetAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  transferTo           User?          @relation("AssetTransferTarget", fields: [transferToId], references: [id], onDelete: SetNull)
  history              AssetHistory[]
}

model AssetHistory {
  id            String          @id @default(cuid())
  assetId       String
  changeType    AssetChangeType
  field         String?
  previousValue String?
  newValue      String?
  note          String?
  actedById     String?
  createdAt     DateTime        @default(now())
  asset         Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  actedBy       User?           @relation("AssetHistoryActor", fields: [actedById], references: [id], onDelete: SetNull)
}

model Facility {
  id          String           @id @default(cuid())
  name        String
  category    FacilityCategory @default(ROOM)
  capacity    Int              @default(0)
  building    String
  location    String
  equipment   String?
  description String?
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bookings    Booking[]
}

model Booking {
  id              String        @id @default(cuid())
  facilityId      String
  requesterId     String
  date            DateTime
  startTime       String
  endTime         String
  purpose         String
  attendeeCount   Int           @default(1)
  status          BookingStatus @default(PENDING)
  decisionComment String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  facility        Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  requester       User          @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([facilityId, date])
  @@index([requesterId])
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String
  category      String
  startsAt      DateTime
  endsAt        DateTime
  venue         String
  capacity      Int
  eligibility   String?
  status        EventStatus         @default(DRAFT)
  checkInToken  String              @unique @default(cuid())
  organizerId   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  organizer     User                @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
  feedback      EventFeedback[]
}

model EventRegistration {
  id          String             @id @default(cuid())
  eventId     String
  studentId   String
  status      RegistrationStatus @default(REGISTERED)
  checkedInAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student     User               @relation("EventAttendee", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
}

model EventFeedback {
  id        String   @id @default(cuid())
  eventId   String
  studentId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   User     @relation("EventFeedbackAuthor", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
}
