# Copy to `.env` and fill in real values, then restart `npm run dev`.
# Next.js loads `.env` automatically; prisma.config.ts loads it via dotenv.

# REQUIRED — Neon Postgres connection string (the app uses the Neon serverless
# adapter over WebSockets, so this must be a Neon `…neon.tech` endpoint, not a
# plain local Postgres). Without it, every DB query (login, register, etc.) fails.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/smartcampus?sslmode=require"

# OPTIONAL — restrict registration to specific university email domains
# (comma-separated). Leave unset/empty to allow any valid email.
# UNIVERSITY_EMAIL_DOMAINS="campus.edu,students.campus.edu"

# OPTIONAL — used only by `npm run bootstrap:admin` to promote/create an admin.
# ADMIN_EMAIL="admin@campus.edu"
# ADMIN_PASSWORD="change-me-min-8-chars"
# ADMIN_NAME="Campus Administrator"
